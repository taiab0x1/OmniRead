ENV=development
LOG_LEVEL=INFO
APP_NAME=OmniRead
API_V1_PREFIX=/v1

DATABASE_URL=postgresql+psycopg2://omniread:omniread@postgres:5432/omniread
DATABASE_URL_ASYNC=postgresql+asyncpg://omniread:omniread@postgres:5432/omniread
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_KEY_ID=v1

CORS_ORIGINS=https://admin.example.com,http://localhost:5173

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.omniread.app

ADMOB_APP_ID=
ADMOB_SSV_VERIFY_KEY=

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=omniread-assets
R2_PUBLIC_URL=https://assets.example.com

SENTRY_DSN=
ADMIN_IP_ALLOWLIST=

RATE_LIMIT_DEFAULT_PER_MIN=60
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_AD_REWARD_PER_MIN=5
RATE_LIMIT_SEARCH_PER_MIN=30

PASSWORD_ARGON2_TIME_COST=3
PASSWORD_ARGON2_MEMORY_COST=65536
PASSWORD_ARGON2_PARALLELISM=4

MAX_SESSIONS_PER_USER=5
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=10

DEFAULT_FREE_CHAPTERS=3
DEFAULT_CHAPTER_COIN_COST=5
DAILY_LOGIN_COINS=5
REWARDED_AD_COINS=10
REWARDED_AD_COOLDOWN_MIN=30
REWARDED_AD_DAILY_CAP=5
